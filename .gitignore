# ============================================================
# LTI ATS — .gitignore
# ============================================================

# ── OS & editors ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# ── Backend (Java / Maven) ────────────────────────────────────
lti-ats/backend/target/
lti-ats/backend/.tools/

# Maven wrapper JAR (regenerable, no subir binarios)
lti-ats/backend/.mvn/wrapper/maven-wrapper.jar

# Spring Boot overrides locales
lti-ats/backend/src/main/resources/application-local.yml

# Java compilado
*.class
*.jar
*.war
*.ear
hs_err_pid*
replay_pid*

# ── Frontend (Node / Vite) ────────────────────────────────────
lti-ats/frontend/node_modules/
lti-ats/frontend/dist/
lti-ats/frontend/.vite/

# Variables de entorno
lti-ats/frontend/.env
lti-ats/frontend/.env.local
lti-ats/frontend/.env.*.local

# Caché
lti-ats/frontend/.eslintcache
lti-ats/frontend/.stylelintcache

# ── Docker ────────────────────────────────────────────────────
# Se sube docker-compose.yml; se ignoran overrides con secretos locales
docker-compose.override.yml
docker-compose.local.yml

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
